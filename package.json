{
  "name": "classorbit-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 2020",
    "dev:api": "pnpm --filter classorbit-api dev",
    "dev:all": "pnpm run -r --parallel --include-workspace-root dev",
    "db:init:local": "pnpm --filter classorbit-api db:init:local",
    "assets:upload": "pnpm --filter classorbit-api assets:upload",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:preview": "pnpm pages:build && wrangler pages dev .vercel/output/static --port 2020",
    "pages:deploy": "pnpm pages:build && wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^6.1.0",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260609.1",
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.95.0"
  }
}
